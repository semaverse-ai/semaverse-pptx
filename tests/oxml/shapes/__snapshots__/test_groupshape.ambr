    <p:grpSpPr>
      <a:xfrm>
        <a:off x="100" y="200"/>
        <a:ext cx="350" cy="450"/>
        <a:chOff x="100" y="200"/>
        <a:chExt cx="350" cy="450"/>
      </a:xfrm>
    </p:grpSpPr>
    <p:sp>
      <p:spPr>
        <a:xfrm>
          <a:off x="100" y="200"/>
          <a:ext cx="300" cy="400"/>
        </a:xfrm>
      </p:spPr>
    </p:sp>
    <p:sp>
      <p:spPr>
        <a:xfrm>
          <a:off x="150" y="250"/>
          <a:ext cx="300" cy="400"/>
        </a:xfrm>
      </p:spPr>
    </p:sp>
  </p:grpSp>
  
  '''
