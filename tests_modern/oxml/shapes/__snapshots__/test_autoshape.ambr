# name: test_shape_new_textbox_sp
  '''
  <p:sp xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" xmlns:p="http://schemas.openxmlformats.org/presentationml/2006/main">
    <p:nvSpPr>
      <p:cNvPr id="9" name="TextBox 8"/>
      <p:cNvSpPr txBox="1"/>
      <p:nvPr/>
    </p:nvSpPr>
    <p:spPr>
      <a:xfrm>
        <a:off x="111" y="222"/>
        <a:ext cx="333" cy="444"/>
      </a:xfrm>
      <a:prstGeom prst="rect">
        <a:avLst/>
      </a:prstGeom>
      <a:noFill/>
    </p:spPr>
    <p:txBody>
      <a:bodyPr wrap="none">
        <a:spAutoFit/>
      </a:bodyPr>
      <a:lstStyle/>
      <a:p/>
    </p:txBody>
  </p:sp>
  
  '''
